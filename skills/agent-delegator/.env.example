# Inception Labs / Mercury 2 (https://platform.inceptionlabs.ai → API Keys)
# Neue Accounts: 10M kostenlose Tokens. Schnellstes Modell (~1000 tok/s).
# INCEPTION_API_KEY=

# Agent Delegator — API Keys
# Kopiere diese Datei zu .env und trage deine Keys ein.
# Die .env wird NICHT ins Git-Repository eingecheckt.

# Ollama Cloud (https://ollama.com → Account → API Keys)
OLLAMA_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=

# Google Gemini (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=

# Groq (https://console.groq.com/keys)
# GROQ_API_KEY=

# OpenRouter (https://openrouter.ai/keys — 300+ Modelle, kostenlose Tier verfügbar)
# OPENROUTER_API_KEY=
