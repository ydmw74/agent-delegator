{
  "_comment": "Agent Delegator Configuration — edit this file to enable/disable agents and set API keys",
  "agents": [
    {
      "id": "inception-mercury2",
      "type": "openai-compatible",
      "name": "Mercury 2 (Inception Labs — Diffusion LLM, ~1000 tok/s)",
      "api_base": "https://api.inceptionlabs.ai/v1",
      "api_key_env": "INCEPTION_API_KEY",
      "model": "mercury-2",
      "max_tokens": 4096,
      "cost_tier": "very-low",
      "enabled": true,
      "_note": "API-Key: https://platform.inceptionlabs.ai → API Keys. Neue Accounts erhalten 10M kostenlose Tokens.",
      "_extra_params": {
        "diffusing": false,
        "_info": "diffusing=true zeigt Diffusion-Prozess live beim Streaming (optional, für Debug)",
        "reasoning_effort": "low",
        "reasoning_summary": false,
        "_info_temperature": "Min 0.5, default 0.75 — unlike other providers (0.3 NOT valid)"
      },
      "_context_window": "128k",
      "_latency": "~1000 tokens/sec auf H100 — schnellstes verfügbares Modell",
      "_fallback_via_openrouter": "inception/mercury-2",
      "strengths": [
        "text-transformation",
        "formatting",
        "simple-qa",
        "template-filling",
        "summarization",
        "translation",
        "code-completion",
        "sehr-schnell",
        "grosser-kontext"
      ],
      "temperature_range": "0.5-1.0",
      "temperature_default": 0.75,
      "reasoning_effort": [
        "instant",
        "low",
        "medium",
        "high"
      ],
      "max_tokens_range": "1-50000"
    },
    {
      "id": "ollama-cloud",
      "type": "openai-compatible",
      "name": "Ollama Cloud (gehostet, OpenAI-kompatibel)",
      "api_base": "https://ollama.com/v1",
      "api_key_env": "OLLAMA_API_KEY",
      "model": "gemma3:4b",
      "max_tokens": 4096,
      "cost_tier": "very-low",
      "enabled": true,
      "_note": "Standard-Agent. API-Key: https://ollama.com → Account → API Keys. export OLLAMA_API_KEY=...",
      "_url_override": "Eigene Cloud-Instanz: OLLAMA_CLOUD_URL=https://dein-server.com/v1 setzen und api_base anpassen",
      "strengths": [
        "text-transformation",
        "formatting",
        "simple-qa",
        "template-filling",
        "summarization",
        "cloud-verfügbar",
        "kein-eigenes-hardware"
      ],
      "_available_models": {
        "small": [
          "gemma3:4b",
          "ministral-3:3b"
        ],
        "medium": [
          "gemma3:12b",
          "ministral-3:8b"
        ],
        "large": [
          "gemma3:27b",
          "ministral-3:14b",
          "gpt-oss:20b"
        ]
      }
    },
    {
      "id": "gpt-4o-mini",
      "type": "openai-compatible",
      "name": "GPT-4o Mini (OpenAI)",
      "api_base": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-4o-mini",
      "max_tokens": 4096,
      "cost_tier": "low",
      "enabled": true,
      "strengths": [
        "text-transformation",
        "formatting",
        "code-completion",
        "documentation",
        "translation",
        "summarization",
        "template-filling",
        "regex-parsing"
      ]
    },
    {
      "id": "gemini-flash",
      "type": "openai-compatible",
      "name": "Gemini 2.0 Flash (Google)",
      "api_base": "https://generativelanguage.googleapis.com/v1beta/openai",
      "api_key_env": "GEMINI_API_KEY",
      "model": "gemini-2.0-flash",
      "max_tokens": 8192,
      "cost_tier": "low",
      "enabled": false,
      "strengths": [
        "text-transformation",
        "long-context",
        "code-completion",
        "documentation",
        "translation",
        "summarization"
      ]
    },
    {
      "id": "groq-llama",
      "type": "openai-compatible",
      "name": "Llama 3.1 8B (Groq — sehr schnell, sehr günstig)",
      "api_base": "https://api.groq.com/openai/v1",
      "api_key_env": "GROQ_API_KEY",
      "model": "llama-3.1-8b-instant",
      "max_tokens": 4096,
      "cost_tier": "very-low",
      "enabled": false,
      "strengths": [
        "text-transformation",
        "formatting",
        "simple-qa",
        "template-filling"
      ]
    },
    {
      "id": "ollama-local",
      "type": "ollama",
      "name": "Lokales Modell via Ollama (kein API-Key nötig, kostenlos, offline)",
      "api_base": "http://localhost:11434",
      "model": "llama3.2",
      "max_tokens": 4096,
      "cost_tier": "free",
      "enabled": true,
      "_note": "Aktiviert sobald Ollama läuft. Modell laden: ollama pull llama3.2",
      "strengths": [
        "text-transformation",
        "formatting",
        "simple-qa",
        "offline",
        "datenschutz"
      ]
    },
    {
      "id": "openrouter",
      "type": "openai-compatible",
      "name": "OpenRouter (Modell-Aggregator, 300+ Modelle)",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "model": "google/gemma-3-4b-it:free",
      "max_tokens": 4096,
      "cost_tier": "very-low",
      "enabled": true,
      "_note": "API-Key: https://openrouter.ai → Keys. Zugang zu 300+ Modellen incl. kostenlose Tier-Modelle.",
      "_extra_headers": {
        "HTTP-Referer": "https://github.com/ydmw74/agent-delegator",
        "X-Title": "Agent Delegator"
      },
      "_available_models": {
        "free": [
          "google/gemma-3-4b-it:free",
          "google/gemma-3-12b-it:free",
          "meta-llama/llama-3.1-8b-instruct:free",
          "mistralai/mistral-7b-instruct:free",
          "qwen/qwen-2.5-7b-instruct:free"
        ],
        "low-cost": [
          "google/gemma-3-27b-it",
          "meta-llama/llama-3.1-70b-instruct",
          "mistralai/mistral-small-3.1-24b-instruct",
          "qwen/qwen-2.5-72b-instruct"
        ],
        "mid-range": [
          "anthropic/claude-haiku-4-5",
          "openai/gpt-4o-mini",
          "google/gemini-flash-1.5"
        ]
      },
      "strengths": [
        "text-transformation",
        "formatting",
        "simple-qa",
        "template-filling",
        "summarization",
        "translation",
        "code-completion",
        "documentation",
        "modell-vielfalt",
        "kostenlose-modelle"
      ]
    },
    {
      "id": "opencode",
      "type": "opencode-cli",
      "name": "opencode CLI",
      "model": "claude-haiku-4-5-20251001",
      "cost_tier": "low",
      "enabled": false,
      "strengths": [
        "code-generation",
        "code-review",
        "refactoring",
        "debugging",
        "file-operations"
      ]
    }
  ],
  "routing_rules": {
    "simple": [
      "inception-mercury2",
      "ollama-cloud",
      "openrouter",
      "ollama-local",
      "groq-llama",
      "gpt-4o-mini",
      "gemini-flash"
    ],
    "medium": [
      "inception-mercury2",
      "ollama-cloud",
      "openrouter",
      "gpt-4o-mini",
      "gemini-flash",
      "ollama-local",
      "opencode"
    ],
    "complex": "claude-direct"
  },
  "defaults": {
    "timeout_seconds": 60,
    "retry_on_error": true,
    "max_retries": 2,
    "fallback_to_claude": true
  }
}